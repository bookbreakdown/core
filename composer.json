{
    "name": "turnkeyagentic/core",
    "description": "TurnkeyAgentic shared core services - PdoDB, AI providers, storage",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "google/apiclient": "^2.19",
        "google/auth": "^1.50",
        "guzzlehttp/guzzle": "^7.10"
    },
    "suggest": {
        "codeigniter4/framework": "Required for PdoDB and DownloadService (^4.7)"
    },
    "autoload": {
        "psr-4": {
            "TurnkeyAgentic\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TurnkeyAgentic\\Core\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    }
}
